generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String          @id @default(cuid())
  account           String          @unique
  phone             String?         @unique
  passwordHash      String
  name              String
  role              UserRole        @default(USER)
  status            UserStatus      @default(ACTIVE)
  creditBalance     Decimal         @default(0) @db.Decimal(18, 2)
  expiresAt         DateTime?
  lastLoginAt       DateTime?
  passwordUpdatedAt DateTime?
  deletedAt         DateTime?
  quotas            UserTokenQuota?
  sessions          AuthSession[]
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([status])
  @@index([expiresAt])
}

model UserTokenQuota {
  id            String   @id @default(cuid())
  userId        String   @unique
  gptTokens     Int      @default(0)
  geminiTokens  Int      @default(0)
  jmTokens      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuthSession {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String
  expiresAt        DateTime
  revokedAt        DateTime?
  lastUsedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum UserRole {
  ADMIN
  USER
}
